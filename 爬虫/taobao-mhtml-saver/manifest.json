{
  "manifest_version": 3,
  "name": "淘宝店铺MHTML保存器",
  "version": "1.0",
  "description": "自动保存淘宝店铺商品详情页为MHTML格式",
  "permissions": [
    "activeTab",
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "*://*.taobao.com/*",
    "*://*.jiyoujia.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.taobao.com/*", "*://*.jiyoujia.com/*"],
      "js": ["content.js"]
    }
  ]
}