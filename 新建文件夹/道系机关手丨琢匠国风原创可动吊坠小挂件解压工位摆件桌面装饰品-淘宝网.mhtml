@charset "utf-8";

.rc-dialog { margin: 10px; position: relative; width: auto; }

.rc-dialog-wrap { inset: 0px; outline: 0px; overflow: auto; position: fixed=
; z-index: 1050; }

.rc-dialog-title { font-size: 14px; font-weight: 700; line-height: 21px; ma=
rgin: 0px; }

.rc-dialog-content { background-clip: padding-box; background-color: rgb(25=
5, 255, 255); border: none; border-radius: 6px; position: relative; }

.rc-dialog-close { background: transparent; border: 0px; color: rgb(0, 0, 0=
); cursor: pointer; font-size: 21px; font-weight: 700; line-height: 1; opac=
ity: 0.2; right: 20px; text-decoration: none; text-shadow: rgb(255, 255, 25=
5) 0px 1px 0px; top: 12px; }

.rc-dialog-close:disabled { pointer-events: none; }

.rc-dialog-close-x::after { content: "=C3=97"; }

.rc-dialog-close:hover { opacity: 1; text-decoration: none; }

.rc-dialog-header { background: rgb(255, 255, 255); border-bottom: 1px soli=
d rgb(233, 233, 233); border-radius: 5px 5px 0px 0px; color: rgb(102, 102, =
102); padding: 13px 20px 14px; }

.rc-dialog-body { padding: 20px; }

.rc-dialog-footer { border-radius: 0px 0px 5px 5px; border-top: 1px solid r=
gb(233, 233, 233); padding: 10px 20px; text-align: right; }

.rc-dialog-zoom-appear, .rc-dialog-zoom-enter { animation-duration: 0.3s; a=
nimation-fill-mode: both; animation-play-state: paused; animation-timing-fu=
nction: cubic-bezier(0.08, 0.82, 0.17, 1); opacity: 0; }

.rc-dialog-zoom-leave { animation-duration: 0.3s; animation-fill-mode: both=
; animation-play-state: paused; animation-timing-function: cubic-bezier(0.6=
, 0.04, 0.98, 0.34); }

.rc-dialog-zoom-appear.rc-dialog-zoom-appear-active, .rc-dialog-zoom-enter.=
rc-dialog-zoom-enter-active { animation-name: rcDialogZoomIn; animation-pla=
y-state: running; }

.rc-dialog-zoom-leave.rc-dialog-zoom-leave-active { animation-name: rcDialo=
gZoomOut; animation-play-state: running; }

@keyframes rcDialogZoomIn {=20
  0% { opacity: 0; transform: scale(0); }
  100% { opacity: 1; transform: scale(1); }
}

@keyframes rcDialogZoomOut {=20
  0% { transform: scale(1); }
  100% { opacity: 0; transform: scale(0); }
}

@media (min-width: 768px) {
  .rc-dialog { margin: 30px auto; width: 600px; }
}

.rc-dialog-mask { background-color: rgba(55, 55, 55, 0.6); inset: 0px; heig=
ht: 100%; position: fixed; z-index: 1050; }

.rc-dialog-mask-hidden { display: none; }

.rc-dialog-fade-appear, .rc-dialog-fade-enter { opacity: 0; }

.rc-dialog-fade-appear, .rc-dialog-fade-enter, .rc-dialog-fade-leave { anim=
ation-duration: 0.3s; animation-fill-mode: both; animation-play-state: paus=
ed; animation-timing-function: cubic-bezier(0.55, 0, 0.55, 0.2); }

.rc-dialog-fade-appear.rc-dialog-fade-appear-active, .rc-dialog-fade-enter.=
rc-dialog-fade-enter-active { animation-name: rcDialogFadeIn; animation-pla=
y-state: running; }

.rc-dialog-fade-leave.rc-dialog-fade-leave-active { animation-name: rcDialo=
gFadeOut; animation-play-state: running; }

@keyframes rcDialogFadeIn {=20
  0% { opacity: 0; }
  100% { opacity: 1; }
}

@keyframes rcDialogFadeOut {=20
  0% { opacity: 1; }
  100% { opacity: 0; }
}

